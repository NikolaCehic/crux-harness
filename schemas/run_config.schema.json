{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crux.local/schemas/run_config.schema.json",
  "title": "RunConfig",
  "type": "object",
  "required": [
    "schema_version",
    "harness_version",
    "run_id",
    "created_at",
    "input",
    "source_policy",
    "source_pack",
    "budgets",
    "mappers",
    "prompts"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "crux.run_config.v1" },
    "harness_version": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "required": ["path", "copied_path", "content_hash"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "copied_path": { "type": "string", "minLength": 1 },
        "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "source_policy": { "type": "string", "minLength": 1 },
    "source_pack": { "type": ["string", "null"] },
    "budgets": {
      "type": "object",
      "required": ["max_research_items", "max_agent_steps", "max_llm_calls"],
      "properties": {
        "max_research_items": { "type": ["integer", "null"], "minimum": 0 },
        "max_agent_steps": { "type": ["integer", "null"], "minimum": 0 },
        "max_llm_calls": { "type": ["integer", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "mappers": {
      "type": "object",
      "required": ["claim_decomposer", "evidence_mapper"],
      "properties": {
        "claim_decomposer": { "$ref": "#/$defs/mapper" },
        "evidence_mapper": { "$ref": "#/$defs/mapper" }
      },
      "additionalProperties": false
    },
    "prompts": {
      "type": "object",
      "required": ["claim_decomposer", "evidence_mapper"],
      "properties": {
        "claim_decomposer": { "type": "string", "minLength": 1 },
        "evidence_mapper": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "mapper": {
      "type": "object",
      "required": ["type", "reason"],
      "properties": {
        "type": { "type": "string", "enum": ["deterministic", "llm"] },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
