{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crux.local/schemas/eval_report.schema.json",
  "title": "EvalReport",
  "type": "object",
  "required": ["scores", "findings", "failed_checks", "improvement_recommendations", "council"],
  "properties": {
    "scores": {
      "type": "object",
      "required": [
        "schema_validity",
        "claim_graph_integrity",
        "claim_coverage",
        "evidence_traceability",
        "source_quality",
        "contradiction_handling",
        "red_team_strength",
        "uncertainty_quality",
        "faithfulness",
        "crux_quality",
        "decision_usefulness"
      ],
      "properties": {
        "schema_validity": { "type": "number", "minimum": 0, "maximum": 1 },
        "claim_graph_integrity": { "type": "number", "minimum": 0, "maximum": 1 },
        "claim_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_traceability": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_quality": { "type": "number", "minimum": 0, "maximum": 1 },
        "contradiction_handling": { "type": "number", "minimum": 0, "maximum": 1 },
        "red_team_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "uncertainty_quality": { "type": "number", "minimum": 0, "maximum": 1 },
        "faithfulness": { "type": "number", "minimum": 0, "maximum": 1 },
        "crux_quality": { "type": "number", "minimum": 0, "maximum": 1 },
        "decision_usefulness": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failed_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "improvement_recommendations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "council": {
      "type": "object",
      "required": ["schema_version", "reviewers", "disagreements", "synthesis"],
      "properties": {
        "schema_version": { "const": "crux.eval_council.v1" },
        "reviewers": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "object",
            "required": [
              "role_id",
              "role_name",
              "status",
              "score",
              "stage",
              "findings",
              "blocking_failures",
              "recommendations"
            ],
            "properties": {
              "role_id": {
                "enum": [
                  "evidence_auditor",
                  "claim_graph_auditor",
                  "faithfulness_auditor",
                  "red_team_auditor",
                  "uncertainty_auditor",
                  "decision_utility_auditor",
                  "domain_reviewer",
                  "synthesis_judge"
                ]
              },
              "role_name": { "type": "string", "minLength": 1 },
              "status": { "enum": ["pass", "warn", "fail"] },
              "score": { "type": "number", "minimum": 0, "maximum": 1 },
              "stage": { "type": "string", "minLength": 1 },
              "findings": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blocking_failures": {
                "type": "array",
                "items": { "type": "string" }
              },
              "recommendations": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "disagreements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["topic", "severity", "positions"],
            "properties": {
              "topic": { "type": "string", "minLength": 1 },
              "severity": { "enum": ["low", "medium", "high"] },
              "positions": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "required": ["role_id", "position", "status"],
                  "properties": {
                    "role_id": {
                      "enum": [
                        "evidence_auditor",
                        "claim_graph_auditor",
                        "faithfulness_auditor",
                        "red_team_auditor",
                        "uncertainty_auditor",
                        "decision_utility_auditor",
                        "domain_reviewer",
                        "synthesis_judge"
                      ]
                    },
                    "position": { "type": "string", "minLength": 1 },
                    "status": { "enum": ["pass", "warn", "fail"] }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "synthesis": {
          "type": "object",
          "required": ["status", "confidence", "blocking_failures", "next_fixes"],
          "properties": {
            "status": { "enum": ["pass", "warn", "fail"] },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "blocking_failures": {
              "type": "array",
              "items": { "type": "string" }
            },
            "next_fixes": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
