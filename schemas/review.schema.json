{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crux.local/schemas/review.schema.json",
  "title": "Review",
  "type": "object",
  "required": ["schema_version", "run_id", "created_at", "updated_at", "actions", "summary"],
  "properties": {
    "schema_version": { "const": "crux.review.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "created_at", "reviewer", "action_type", "target", "rationale", "metadata"],
        "properties": {
          "id": { "type": "string", "pattern": "^R[0-9]+$" },
          "created_at": { "type": "string", "minLength": 1 },
          "reviewer": { "type": "string", "minLength": 1 },
          "action_type": {
            "enum": ["approve_claim", "reject_claim", "annotate_evidence", "request_stage_rerun"]
          },
          "target": {
            "type": "object",
            "required": ["type", "id"],
            "properties": {
              "type": { "enum": ["claim", "evidence", "stage"] },
              "id": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "rationale": { "type": "string" },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["approved_claims", "rejected_claims", "evidence_annotations", "stage_rerun_requests"],
      "properties": {
        "approved_claims": {
          "type": "array",
          "items": { "type": "string", "pattern": "^C[0-9]+$" }
        },
        "rejected_claims": {
          "type": "array",
          "items": { "type": "string", "pattern": "^C[0-9]+$" }
        },
        "evidence_annotations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["evidence_id", "note_count"],
            "properties": {
              "evidence_id": { "type": "string", "pattern": "^E[0-9]+$" },
              "note_count": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "stage_rerun_requests": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
