{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crux.local/schemas/uncertainty.schema.json",
  "title": "Uncertainty",
  "type": "object",
  "required": [
    "overall_confidence",
    "key_uncertainties",
    "sensitivity",
    "what_would_change_my_mind",
    "recommended_tests"
  ],
  "properties": {
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "key_uncertainties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "current_estimate",
          "confidence",
          "impact_if_wrong",
          "evidence_needed"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^U[0-9]+$" },
          "description": { "type": "string", "minLength": 1 },
          "current_estimate": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "impact_if_wrong": { "type": "string", "minLength": 1 },
          "evidence_needed": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "sensitivity": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assumption", "low_case", "base_case", "high_case", "decision_impact"],
        "properties": {
          "assumption": { "type": "string", "minLength": 1 },
          "low_case": { "type": "string", "minLength": 1 },
          "base_case": { "type": "string", "minLength": 1 },
          "high_case": { "type": "string", "minLength": 1 },
          "decision_impact": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "what_would_change_my_mind": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_tests": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}

