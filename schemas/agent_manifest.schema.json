{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crux.local/schemas/agent_manifest.schema.json",
  "title": "AgentManifest",
  "type": "object",
  "required": ["schema_version", "mode", "agents"],
  "properties": {
    "schema_version": { "type": "string", "const": "crux.agent_manifest.v1" },
    "mode": { "type": "string", "const": "bounded" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "agent_id",
          "name",
          "role",
          "stage",
          "autonomy",
          "purpose",
          "allowed_inputs",
          "produced_outputs",
          "limits"
        ],
        "properties": {
          "agent_id": {
            "enum": [
              "research_scout",
              "evidence_auditor",
              "red_team_agent",
              "council_moderator",
              "replay_planner",
              "eval_scenario_agent"
            ]
          },
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "stage": { "type": "string", "minLength": 1 },
          "autonomy": { "type": "string", "const": "bounded" },
          "purpose": { "type": "string", "minLength": 1 },
          "allowed_inputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "produced_outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "limits": {
            "type": "object",
            "required": ["no_external_side_effects", "max_steps", "requires_trace"],
            "properties": {
              "no_external_side_effects": { "type": "boolean" },
              "max_steps": { "type": "integer", "minimum": 1 },
              "requires_trace": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
