{
  "name": "crux-harness",
  "version": "0.1.0",
  "description": "Spec-driven harness for decision-grade analysis agents.",
  "type": "module",
  "bin": {
    "crux": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "crux": "npm run build --silent && node dist/src/cli.js",
    "benchmark": "npm run crux -- benchmark"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^14.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
