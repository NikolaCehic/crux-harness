{
  "schema_version": "crux.pack.v1",
  "name": "investment-diligence",
  "display_name": "Investment Diligence",
  "version": "1.0.0",
  "analysis_scope": "investment-diligence",
  "description": "Evaluates whether an investor should advance, defer, or reject a company or thesis.",
  "input_template": {
    "output_goal": "investment diligence memo",
    "time_horizon": "18 months",
    "risk_tolerance": "medium-high",
    "known_constraints": [
      "Separate buyer urgency from founder narrative.",
      "Distinguish audited traction from pipeline claims."
    ]
  },
  "source_requirements": {
    "min_sources": 3,
    "required_source_types": ["internal_document", "expert_input", "dataset"],
    "required_questions": [
      "What evidence supports buyer urgency?",
      "What evidence weakens revenue quality?",
      "What competitive pressure could compress the upside?"
    ]
  },
  "claim_taxonomy": ["market pull", "revenue quality", "durable differentiation", "execution risk", "investment decision"],
  "expected_evidence_types": ["customer references", "revenue cohort data", "competitive analysis", "pilot conversion evidence"],
  "known_failure_modes": ["overweighting founder claims", "ignoring weak revenue quality", "underestimating incumbent bundling"],
  "eval_rubric": {
    "min_scores": {
      "faithfulness": 1,
      "evidence_traceability": 1,
      "decision_usefulness": 1
    },
    "required_diagnostics": []
  },
  "memo_sections": ["Recommendation", "Evidence Quality", "Red-Team Findings", "What Would Change This Decision"],
  "benchmark": {
    "scenario": "e2e/scenarios/investment-diligence.yaml",
    "expectation": "e2e/expectations/investment-diligence.json"
  }
}
