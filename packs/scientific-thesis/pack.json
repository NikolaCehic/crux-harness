{
  "schema_version": "crux.pack.v1",
  "name": "scientific-thesis",
  "display_name": "Scientific Thesis",
  "version": "1.0.0",
  "analysis_scope": "scientific-thesis",
  "description": "Evaluates a scientific or technical thesis against evidence, mechanisms, limitations, and falsifiers.",
  "input_template": {
    "output_goal": "technical thesis evaluation memo",
    "time_horizon": "12 months",
    "risk_tolerance": "medium",
    "known_constraints": [
      "Separate benchmark evidence from mechanism evidence.",
      "Identify falsifying experiments."
    ]
  },
  "source_requirements": {
    "min_sources": 3,
    "required_source_types": ["paper", "dataset", "web"],
    "required_questions": [
      "What evidence directly supports the mechanism?",
      "What evidence challenges generalization?",
      "What experiment would falsify the thesis?"
    ]
  },
  "claim_taxonomy": ["mechanism", "benchmark evidence", "generalization risk", "falsifier", "research decision"],
  "expected_evidence_types": ["paper result", "benchmark comparison", "dataset limitation", "replication signal"],
  "known_failure_modes": ["overgeneralizing benchmarks", "ignoring freshness or provenance", "hiding negative evidence"],
  "eval_rubric": {
    "min_scores": {
      "faithfulness": 1,
      "evidence_traceability": 1,
      "uncertainty_quality": 1
    },
    "required_diagnostics": []
  },
  "memo_sections": ["Recommendation", "Evidence Quality", "Uncertainty", "What Would Change This Decision"],
  "benchmark": {
    "scenario": "e2e/scenarios/scientific-thesis.yaml",
    "expectation": "e2e/expectations/scientific-thesis.json"
  }
}
