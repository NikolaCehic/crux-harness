{
  "schema_version": "crux.pack.v1",
  "name": "policy-analysis",
  "display_name": "Policy Analysis",
  "version": "1.0.0",
  "analysis_scope": "policy-analysis",
  "description": "Evaluates a policy intervention against feasibility, incentives, evidence, and unintended consequences.",
  "input_template": {
    "output_goal": "policy decision memo",
    "time_horizon": "36 months",
    "risk_tolerance": "medium",
    "known_constraints": [
      "Separate policy intent from implementation incentives.",
      "Identify distributional effects and participation risk."
    ]
  },
  "source_requirements": {
    "min_sources": 3,
    "required_source_types": ["dataset", "internal_document", "expert_input"],
    "required_questions": [
      "Who changes behavior under the policy?",
      "What administrative constraint can block the policy?",
      "What evidence shows cost effectiveness?"
    ]
  },
  "claim_taxonomy": ["policy mechanism", "stakeholder incentive", "implementation feasibility", "unintended consequence", "policy decision"],
  "expected_evidence_types": ["administrative data", "stakeholder input", "cost model", "implementation precedent"],
  "known_failure_modes": ["assuming participation", "hiding distributional tradeoffs", "overlooking administrative capacity"],
  "eval_rubric": {
    "min_scores": {
      "faithfulness": 1,
      "contradiction_handling": 1,
      "uncertainty_quality": 1
    },
    "required_diagnostics": []
  },
  "memo_sections": ["Recommendation", "Red-Team Findings", "Uncertainty", "What Would Change This Decision"],
  "benchmark": {
    "scenario": "e2e/scenarios/policy-analysis.yaml",
    "expectation": "e2e/expectations/policy-analysis.json"
  }
}
